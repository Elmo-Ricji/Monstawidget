<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_frame"
        android:padding="8dp">


        <ImageView
            android:id="@+id/widgetBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="background"/>


        <LinearLayout
            android:id="@+id/monstaSlot0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp">
            <TextView
                android:id="@+id/cloud0"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:background="@drawable/thought_cloud_bg"
                android:padding="4dp"
                android:textSize="9sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"/>
            <ImageView
                android:id="@+id/monsta0"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerInside"
                android:contentDescription="monsta"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/monstaSlot1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true"
            android:layout_marginTop="4dp">
            <TextView
                android:id="@+id/cloud1"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:background="@drawable/thought_cloud_bg"
                android:padding="4dp"
                android:textSize="9sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"/>
            <ImageView
                android:id="@+id/monsta1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerInside"
                android:contentDescription="monsta"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/monstaSlot2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp">
            <TextView
                android:id="@+id/cloud2"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:background="@drawable/thought_cloud_bg"
                android:padding="4dp"
                android:textSize="9sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"/>
            <ImageView
                android:id="@+id/monsta2"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerInside"
                android:contentDescription="monsta"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/monstaSlot3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/cloud3"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:background="@drawable/thought_cloud_bg"
                android:padding="4dp"
                android:textSize="9sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"/>
            <ImageView
                android:id="@+id/monsta3"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerInside"
                android:contentDescription="monsta"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/monstaSlot4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/cloud4"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:background="@drawable/thought_cloud_bg"
                android:padding="4dp"
                android:textSize="9sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"/>
            <ImageView
                android:id="@+id/monsta4"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerInside"
                android:contentDescription="monsta"/>
        </LinearLayout>

    </RelativeLayout>

</FrameLayout>