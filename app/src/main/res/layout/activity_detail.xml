<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/detailThoughtCloud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/thought_cloud_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textSize="13sp"
                android:maxWidth="260dp"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <ImageView
                android:id="@+id/detailCreatureImage"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:contentDescription="creature"
                android:scaleType="centerInside"/>

        </LinearLayout>

        <TextView
            android:id="@+id/detailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20000000"
            android:alpha="0.15"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/detailBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="32dp"/>


        <Button
            android:id="@+id/shareButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#4A90D9"
            android:text="share"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/editButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#6B4F3A"
            android:text="edit"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/doneButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="free my monsta"
            android:backgroundTint="#3DAA6A"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>